# EcoLink Australia — Environment Configuration Template
# Copy to `.env` for local dev; mirror every variable into Railway → Variables
# for production. See DEPLOY.md for full context.

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                 # openssl rand -base64 32

# ─── Database & Cache (Railway injects these in prod) ─────────────────────────
DATABASE_URL=                    # postgres://user:pass@host:5432/db
REDIS_URL=                       # redis://default:pass@host:6379
ECOLINK_APP_DB_PASSWORD=         # openssl rand -base64 32   (≥16 chars, used by migration 004)

# ─── Stripe (Billing + GST via Stripe Tax) ────────────────────────────────────
STRIPE_SECRET_KEY=               # sk_live_… or sk_test_…
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=           # whsec_… — from /api/billing/webhook endpoint in Stripe
STRIPE_PRICE_STARTER=            # price_… — AUD $49/mo recurring
STRIPE_PRICE_PROFESSIONAL=       # price_… — AUD $99/mo recurring
STRIPE_PRICE_ENTERPRISE=         # price_… — AUD $149/mo recurring

# ─── Xero Integration (OAuth 2.0) ─────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/auth/xero/callback
TOKEN_ENCRYPTION_KEY=            # openssl rand -hex 32      (64-hex chars, AES-256-GCM)

# ─── MYOB Integration (optional) ──────────────────────────────────────────────
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
MYOB_REDIRECT_URI=http://localhost:3000/api/auth/myob/callback

# ─── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ─── Email (Resend — transactional) ───────────────────────────────────────────
RESEND_API_KEY=                  # re_…

# ─── Notifications (admin — optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Internal Security ────────────────────────────────────────────────────────
INTERNAL_API_KEY=                # openssl rand -base64 32   (protege os endpoints FastAPI)
